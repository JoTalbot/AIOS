# Copy this file to .env. Do not commit .env or paste real values into tickets.
# Generate a value with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIOS_API_KEYS={"replace-with-a-long-random-api-key":{"subject":"local-operator","roles":["admin"]}}

# Required only by the production Compose stack. Use a unique long password.
GRAFANA_PASSWORD=replace-with-a-unique-long-password

# Optional integrations
AIOS_TELEGRAM_TOKEN=
