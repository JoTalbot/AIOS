{
  "title": "AIOS \u2014 API & Infrastructure (v9.3.1)",
  "uid": "aios-api-infra",
  "tags": [
    "aios",
    "api",
    "infrastructure"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "API Uptime",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "up{job=\"aios\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "rate(aios_requests_total[1m])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "rate(aios_errors_total[1m]) / rate(aios_requests_total[1m]) * 100",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "aios_active_connections",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(aios_requests_total[30s])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(aios_errors_total[30s]) / rate(aios_requests_total[30s]) * 100",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 20,
      "title": "Response Time p50",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(aios_response_time_seconds_bucket[1m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 21,
      "title": "Response Time p95",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 9,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(aios_response_time_seconds_bucket[1m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 22,
      "title": "Response Time p99",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 9,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(aios_response_time_seconds_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 30,
      "title": "OLX Cards Collected",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "aios_cards_collected{platform=\"olx\"}",
          "legendFormat": "OLX"
        }
      ]
    },
    {
      "id": 31,
      "title": "Outbox Pending",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "aios_outbox_pending",
          "legendFormat": "{{platform}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}